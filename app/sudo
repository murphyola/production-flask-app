[Unit]
Description=Gunicorn instance to serve Flask Application
After=network.target

[Service]
User=ubuntu
Group=www-data
WorkingDirectory=/home/ubuntu/production-flask-app/app
Environment="PATH=/home/ubuntu/production-flask-app/app/venv/bin"

ExecStart=/home/ubuntu/production-flask-app/app/venv/bin/gunicorn \
    --workers 3 \
    --bind 127.0.0.1:8000 \
    app:app

Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
